# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# HTTP API (ingest webhook + playback + chat + admin all share this listener)
PORT=8080
RUST_LOG=info,live_platform=debug,sqlx=warn,async_nats=warn
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# A stable id for THIS pod, stamped on cross-node chat messages so a pod drops
# its own echoes (V4 loop prevention). In k8s, set this to the pod name.
NODE_ID=node-a

# --- Control plane: Postgres (durable stream sessions; source of truth, V1) ---
DATABASE_URL=postgres://live:live@localhost:5416/live
DB_MAX_CONNECTIONS=16
# Cap on concurrently live streams this control plane admits (backpressure).
MAX_STREAMS=1000

# --- ABR ladder + segmenting (V1/V3) ---
SEGMENT_SECS=4               # target HLS segment duration
PART_SECS=0.5                # LL-HLS partial-segment duration (< SEGMENT_SECS)

# --- Transcode queue: NATS JetStream (durable log to the worker pool, V2) ---
NATS_URL=nats://localhost:4216
TRANSCODE_STREAM=TRANSCODE   # JetStream stream backing the transcode queue
TRANSCODE_LEASE_SECS=60      # visibility timeout: a claimed job redelivers if a worker dies
# The autoscaler knobs: HPA scales the worker Deployment so backlog-per-replica
# stays near TARGET_BACKLOG_PER_WORKER, up to MAX_TRANSCODE_REPLICAS.
TARGET_BACKLOG_PER_WORKER=4
MAX_TRANSCODE_REPLICAS=50

# --- Edge delivery (V3) ---
# Where the packager writes segments/playlists; the edge fetches through to it on a miss.
PACKAGER_ORIGIN=http://localhost:9000

# --- Chat bus: Redis pub/sub for cross-node fan-out (V4) ---
REDIS_URL=redis://localhost:6316/0
# How far a slow viewer's outbox may lag before the slow-consumer policy drops them.
OUTBOX_CAPACITY=256

# --- Background loops (control-plane reconcile, transcode queue setup, chat bus) ---
# Off by default so the bare scaffold serves the API without hitting a V1/V2/V4
# todo!(). Flip to true once those verticals are implemented.
RUN_BACKGROUND=false
