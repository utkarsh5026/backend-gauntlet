# Copy to `.env` and adjust. `.env` is gitignored — never commit real secrets.

# --- Ports ---
# The RESP data plane. 6379 is the redis convention, so `redis-cli` with no arguments
# connects straight to YOUR server. Keep in lockstep with DEFAULT_RESP_PORT in main.rs.
RESP_PORT=6379
# The HTTP sidecar (/healthz, /stats, /metrics) — observation only, never data.
HTTP_PORT=8080

RUST_LOG=info,lsm_redis=debug
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# --- Storage ---
# Where the WAL + SSTable files live. The filesystem IS the database — there is no
# other dependency (no Postgres, no Redis). Gitignored.
DATA_DIR=./data

# Freeze + flush the active memtable to a new SSTable once it holds this many bytes
# (V3 → V4). Small here so a modest test produces several SSTables (and exercises
# compaction); RocksDB's write_buffer_size default is 64 MiB.
MEMTABLE_MAX_BYTES=4194304        # 4 MiB

# When the WAL forces bytes to stable storage (V2) — the durability/throughput dial,
# redis calls it `appendfsync`:
#   always   → fsync every write (safest, slowest)
#   everysec → fsync at most once per second (the redis default — this)
#   no       → never fsync explicitly; rely on the OS page-cache flush (fastest, weakest)
WAL_SYNC=everysec

# --- SSTable / bloom / compaction ---
# Target size of an SSTable data block (V4) — the read + block-cache granularity.
BLOCK_SIZE_BYTES=4096             # 4 KiB
# Bloom filter sizing (V5). ~10 bits/key ≈ 1% false-positive rate (LevelDB's default).
BLOOM_BITS_PER_KEY=10
# Compact once the youngest level holds this many SSTables (V6). This is the count the
# boss fight watches — it must stay bounded under a sustained write flood.
L0_COMPACTION_TRIGGER=4
# Background compaction is OFF by default so the bare scaffold doesn't spawn a loop that
# panics on V6's todo!(). Flip to true once V4 (flush) and V6 (merge) are implemented.
RUN_COMPACTION=false
# How often the background compactor checks whether a level is over its trigger.
COMPACTION_INTERVAL_MS=1000

# --- Block cache (V7) ---
# Byte budget for the hand-built LRU over decoded SSTable blocks. 0 disables the cache
# (every read goes to disk) — the read path works either way; this just bounds read
# amplification. RocksDB's default block cache is 8 MiB.
BLOCK_CACHE_BYTES=8388608         # 8 MiB

# --- Security ---
# Password required on every connection before any command runs (redis `requirepass`).
# Empty = no auth (the default). Clients then `AUTH <password>`. Never logged.
REQUIREPASS=
# Hard cap on a single request's bulk-string length (redis `proto-max-bulk-len`), so a
# hostile length header can't make the parser pre-allocate the process to death.
MAX_REQUEST_BYTES=536870912       # 512 MiB

# --- Reference redis (docker compose) ------------------------------------------------
# Not read by the app — it's where the compose dependency lives, for running redis-cli /
# redis-benchmark against and A/B-comparing semantics. Host port is project-scoped
# (NN=22): redis 6379 → 6322, so it never collides with your server on 6379.
#   Reference redis:   redis-cli -p 6322 ping
