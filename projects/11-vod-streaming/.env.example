# Copy to .env and adjust. There is no database here — the filesystem is the source.

# Port the HTTP server binds.
PORT=8080

# Root of the media library, scanned at startup. Layout:
#   MEDIA_DIR/<asset>/<rendition>.mp4   e.g.  media/bbb/1080p.mp4, media/bbb/720p.mp4
MEDIA_DIR=./media

# Target segment length in seconds. The segmenter aims for this but never splits a
# GOP to hit it (a keyframe boundary always wins).
TARGET_SEGMENT_SECS=6

# Log level (RUST_LOG overrides). LOG_FORMAT=json for machine-readable logs.
RUST_LOG=info,vod_streaming=debug
