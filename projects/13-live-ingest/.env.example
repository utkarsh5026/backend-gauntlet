# Copy to .env and adjust. There is no database here — the source is a live RTMP
# socket and everything downstream lives in a bounded in-memory window.

# Raw-TCP port the RTMP ingest listens on (broadcasters push here).
RTMP_PORT=1935

# HTTP port the LL-HLS delivery server binds (players fetch here).
HTTP_PORT=8080

# Comma-separated list of authorized stream keys. A `publish` to a key not in this
# list is refused and the session closed — an open ingest is a takeover vector.
# Leave EMPTY to allow any key (dev only; never in production).
STREAM_KEYS=testkey

# LL-HLS part target in seconds (~200-350ms). Smaller = lower latency, more overhead.
TARGET_PART_SECS=0.3

# Full segment target in seconds. LL-HLS uses short segments (parts do the latency work).
TARGET_SEGMENT_SECS=4

# How many finished segments to keep in the live window. RAM tracks this, not airtime.
LIVE_WINDOW_SEGMENTS=8

# Log level (RUST_LOG overrides). LOG_FORMAT=json for machine-readable logs.
RUST_LOG=info,live_ingest=debug
