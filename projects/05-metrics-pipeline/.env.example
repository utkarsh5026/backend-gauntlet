# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# HTTP API (ingest + live feed + query)
PORT=8080
RUST_LOG=info,metrics_pipeline=debug,async_nats=warn
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# --- Broker: NATS JetStream (the durable log between ingest and consumer) ---
NATS_URL=nats://localhost:4205
STREAM_NAME=METRICS          # JetStream stream backing the raw-metrics subject

# --- Store: ClickHouse (the queryable home for rolled-up metrics) ---
CLICKHOUSE_URL=http://localhost:8105
CLICKHOUSE_DB=default
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
ROLLUP_TABLE=metrics_rollup

# --- SSE live feed (V4) ---
# Bounded fan-out buffer: how far a dashboard may fall behind before it's shed.
# A slow live client is DROPPED, never allowed to back-pressure the pipeline.
SSE_CAPACITY=1024

# --- Consumer pipeline (rollup -> sink) ---
# Off by default so the bare scaffold serves the ingest API without panicking.
# The pipeline calls the V2 rollup (todo!()), so flip this on once V1/V2 work.
RUN_CONSUMER=false
DURABLE_NAME=rollup-consumer # durable consumer name (remembers its offset)

# --- Rollup windows (V2) ---
WINDOW_SECS=60               # tumbling-window width
GRACE_SECS=10                # watermark grace: wait this long for late points
FLUSH_INTERVAL_MS=1000       # how often to close windows + time-flush the sink

# --- Batched sink (V3) ---
# A column store hates row-at-a-time inserts. Flush when EITHER trigger fires:
BATCH_MAX_ROWS=10000         # size trigger
BATCH_MAX_DELAY_MS=1000      # time trigger (latency ceiling for an idle pipeline)
