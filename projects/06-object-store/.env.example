# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# HTTP API (S3 path-style). 9000 is the MinIO/S3-local convention.
PORT=9000
RUST_LOG=info,object_store=debug
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# --- Storage ---
# Where the store lives. It creates objects/ (content-addressed blobs), tmp/
# (in-flight writes), index/ (the key->blob map), and uploads/ (multipart
# staging) under here. With BLOB_LAYOUT=haystack, volumes/ is used instead of
# (or alongside) objects/ once packing is implemented. The filesystem IS the
# database — there's no other dep.
DATA_DIR=./data

# --- Physical blob layout (swappable under Store) ---
# file_cas (default) — one file per digest under objects/ (today's behaviour).
# haystack — append-only volumes + needle map (scaffold in src/store/haystack.rs;
#            commit/open still todo!() — leave unset until you adopt the lab).
# See docs/11-how-haystack-packing-works.md.
# BLOB_LAYOUT=file_cas
# BLOB_LAYOUT=haystack

# --- Index-as-a-service (From the field) ---
# Host two-process mode (same DATA_DIR):
#   make index-svc
#   INDEX_URL=http://127.0.0.1:9106 make backend
# Leave INDEX_URL unset for the default in-process Index.
INDEX_PORT=9106
# INDEX_URL=http://127.0.0.1:9106
#
# Container stack (index + API + web console) — preferred for the split:
#   make stack
#   console → http://localhost:5106   API → :9006   index → :9106
# Compose sets INDEX_URL=http://index:9106 and a shared volume; you don't need
# INDEX_URL in this file for `make stack`.

# Hard cap on a single object / multipart part, in bytes. Enforced in the stream
# loop (V2) so a client can't stream you out of disk. Default 5 GiB = S3's
# single-PUT ceiling. axum's own 2 MB body limit is disabled in code — this is
# the real limit.
MAX_OBJECT_SIZE=5368709120

# How often the lifecycle background sweep runs (seconds). Expire/tier ages come
# from each bucket's lifecycle policy in metadata.json — this is only cadence.
LIFECYCLE_SCAN_INTERVAL_SECS=60

# --- Chunk-level dedup / CDC (From the field, scaffolded) ---
# Content-defined chunking — NOT Change Data Capture.
# Parsed once at boot into AppState.cdc (main → CdcConfig::from_env → with_cdc).
# Leave CDC_ENABLED unset/false until you implement the todo!()s in
# src/cdc.rs, src/manifest.rs, and streaming::stream_cdc_to_store.
# See docs/10-how-chunk-level-dedup-works.md.
# CDC_ENABLED=false
# CDC_MIN_CHUNK=8192
# CDC_AVG_CHUNK=65536
# CDC_MAX_CHUNK=262144
# CDC_MIN_OBJECT=262144

# --- Auth (presigned URLs + access credentials) ---
# When SECRET_ACCESS_KEY is set, object routes accept EITHER:
#   1) Presigned URL: ?expires=<unix>&signature=<hex>
#      (mint: POST /presign with Authorization: Bearer <ACCESS_KEY_ID>:<SECRET>)
#   2) Access credentials on the normal path:
#      Authorization: Bearer <ACCESS_KEY_ID>:<SECRET>
#      (or Bearer <SECRET> alone)
# Unset SECRET_ACCESS_KEY → open API (dev/tests).
# ACCESS_KEY_ID=local
# SECRET_ACCESS_KEY=
