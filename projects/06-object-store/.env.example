# Copy to `.env` and fill in. `.env` is gitignored ‚Äî never commit real secrets.

# HTTP API (S3 path-style). 9000 is the MinIO/S3-local convention.
PORT=9000
RUST_LOG=info,object_store=debug
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# --- Storage ---
# Where the store lives. It creates objects/ (FileCas blobs), volumes/
# (Haystack needles), tmp/ (in-flight writes), index/ (key‚Üídigest map), and
# uploads/ (multipart staging) under here. The filesystem IS the database ‚Äî
# there's no other dep.
DATA_DIR=./data

# --- Physical blob write policy (both backends always open under DATA_DIR) ---
# file_cas (default) ‚Äî every commit under objects/ (classic one-file-per-digest).
# haystack | hybrid ‚Äî small objects ‚Üí volumes/ needles; oversized ‚Üí objects/.
# Reads use Store's digest‚Üílocation map (index stays key‚Üídigest only).
# See docs/11-how-haystack-packing-works.md.
# BLOB_LAYOUT=file_cas
# BLOB_LAYOUT=haystack
# BLOB_LAYOUT=hybrid
#
# Soft cap for one Haystack volume file, in bytes. Needles that do not fit
# fall back to FileCas under haystack/hybrid policy. Default is 1 MiB
# (1024 * 1024); use 1073741824 (1 GiB) for denser packing in benches.
# HAYSTACK_MAX_VOLUME_SIZE=1073741824
#
# How often background Haystack compaction rewrites dirty volumes (tombstones /
# quarantine). No-op when nothing is dirty. Default 300s.
HAYSTACK_COMPACTION_INTERVAL_SECS=300

# --- Index-as-a-service (From the field) ---
# Host two-process mode (same DATA_DIR):
#   make index-svc
#   INDEX_URL=http://127.0.0.1:9106 make backend
# Leave INDEX_URL unset for the default in-process Index.
INDEX_PORT=9106
# INDEX_URL=http://127.0.0.1:9106
#
# Container stack (index + API + web console) ‚Äî preferred for the split:
#   make stack
#   console ‚Üí http://localhost:5106   API ‚Üí :9006   index ‚Üí :9106
# Compose sets INDEX_URL=http://index:9106 and a shared volume; you don't need
# INDEX_URL in this file for `make stack`.

# Hard cap on a single object / multipart part, in bytes. Enforced in the stream
# loop (V2) so a client can't stream you out of disk. Default 5 GiB = S3's
# single-PUT ceiling. axum's own 2 MB body limit is disabled in code ‚Äî this is
# the real limit.
MAX_OBJECT_SIZE=5368709120

# How often the lifecycle background sweep runs (seconds). Expire/tier ages come
# from each bucket's lifecycle policy in metadata.json ‚Äî this is only cadence.
LIFECYCLE_SCAN_INTERVAL_SECS=60

# --- Chunk-level dedup / CDC (From the field, scaffolded) ---
# Content-defined chunking ‚Äî NOT Change Data Capture.
# Parsed once at boot into AppState.cdc (main ‚Üí CdcConfig::from_env ‚Üí with_cdc).
# Leave CDC_ENABLED unset/false until you implement the todo!()s in
# src/cdc.rs, src/manifest.rs, and streaming::stream_cdc_to_store.
# See docs/10-how-chunk-level-dedup-works.md.
# CDC_ENABLED=false
# CDC_MIN_CHUNK=8192
# CDC_AVG_CHUNK=65536
# CDC_MAX_CHUNK=262144
# CDC_MIN_OBJECT=262144

# --- Auth (presigned URLs + access credentials) ---
# When SECRET_ACCESS_KEY is set, object routes accept EITHER:
#   1) Presigned URL: ?expires=<unix>&signature=<hex>
#      (mint: POST /presign with Authorization: Bearer <ACCESS_KEY_ID>:<SECRET>)
#   2) Access credentials on the normal path:
#      Authorization: Bearer <ACCESS_KEY_ID>:<SECRET>
#      (or Bearer <SECRET> alone)
# Unset SECRET_ACCESS_KEY ‚Üí open API (dev/tests).
# ACCESS_KEY_ID=local
# SECRET_ACCESS_KEY=
