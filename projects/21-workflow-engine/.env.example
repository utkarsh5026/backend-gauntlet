# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# gRPC frontend — where workers and starters connect. 7233 is Temporal's own
# frontend port (a nod); nothing forces it, but it keeps this engine off the
# rate-limiter's 50051 if you run both.
PORT=7233
# Small HTTP sidecar for observability only (/metrics + /healthz).
METRICS_PORT=9090
RUST_LOG=info,workflow_engine=debug,sqlx=warn
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# Postgres — the durable source of truth (history, task queues, timers). Host port
# 5421 = 54NN with NN=21; keep this in lockstep with the code fallback and
# docker-compose.yml.
DATABASE_URL=postgres://workflow:workflow@localhost:5421/workflow
DB_MAX_CONNECTIONS=20

# --- Dispatch / long-poll (V4) ---
# How long PollWorkflowTask / PollActivityTask block before returning "no work". Long
# enough to amortize the round-trip, short enough that a worker notices shutdown.
LONG_POLL_TIMEOUT_MS=5000
# A claimed task that isn't completed within this window is assumed lost (the worker
# crashed) and returned to the queue for another worker — this is what makes delivery
# at-least-once and survives The Reaper.
TASK_VISIBILITY_TIMEOUT_MS=30000

# --- Durable timers (V3) ---
# Off by default so the bare scaffold serves the API without the scan loop panicking
# on its first (todo!()) query. Flip on once V3 is implemented.
RUN_TIMER_SERVICE=false
# How often the timer service scans for due timers. Smaller = tighter firing latency,
# more scan queries; this is a tradeoff you get to measure.
TIMER_SCAN_INTERVAL_MS=200

# --- Sticky cache (V5) ---
# How long an execution stays pinned to the worker that last ran it before follow-up
# tasks fall back to the normal queue (full replay). Ties the cache to worker liveness.
STICKY_TTL_MS=10000
