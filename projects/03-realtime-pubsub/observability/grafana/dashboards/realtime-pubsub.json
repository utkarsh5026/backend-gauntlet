{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "title": "Realtime Pub/Sub — Observability",
  "uid": "realtime-pubsub",
  "tags": ["realtime-pubsub", "backend-gauntlet"],
  "timezone": "",
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Open connections",
      "description": "Live gauge: WebSocket connections currently held open. Incremented on connect, decremented on every teardown path (routes.rs::handle_socket).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(realtime_pubsub_open_connections)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Publish / sec (now)",
      "description": "Client-originated publishes accepted, differentiated over 1m. The input rate to the fan-out (routes.rs::dispatch on ClientMessage::Publish).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(realtime_pubsub_messages_published_total[1m]))"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Deliver / sec (now)",
      "description": "Fan-out deliveries that reached a subscriber's bounded mailbox, over 1m. deliver > publish is the fan-out signal: one publish reaching N subscribers.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(realtime_pubsub_messages_delivered_total[1m]))"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Drops / sec",
      "description": "Messages shed by the backpressure overflow policy (V2). Green at zero; any sustained drops mean a slow consumer is forcing the server to shed — the whole point of the bounded mailbox.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(realtime_pubsub_messages_dropped_total[1m]))"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Throughput — publish vs deliver /s",
      "description": "The fan-out made visible: input (published) vs output (delivered) rates. The gap between them is the amplification factor — how many subscribers each publish reaches.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 12
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(realtime_pubsub_messages_published_total[1m]))",
          "legendFormat": "published/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(realtime_pubsub_messages_delivered_total[1m]))",
          "legendFormat": "delivered/s"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Backpressure — drops & slow-client disconnects /s",
      "description": "The V2 story: messages shed by policy (drop_oldest / drop_newest / disconnect), plus connections reaped because a wedged outbox hit the disconnect policy. Both should sit at zero on a healthy workload.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (policy) (rate(realtime_pubsub_messages_dropped_total[1m]))",
          "legendFormat": "dropped ({{policy}})"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(realtime_pubsub_slow_client_disconnects_total[1m]))",
          "legendFormat": "slow-client disconnects"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Connections, subscriptions & topics",
      "description": "The hub's shape over time: open sockets, total active subscriptions across them (one socket can subscribe to many topics), and the count of distinct topics with at least one subscriber.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(realtime_pubsub_open_connections)",
          "legendFormat": "open connections"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(realtime_pubsub_subscriptions_total)",
          "legendFormat": "subscriptions"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(realtime_pubsub_topics_total)",
          "legendFormat": "topics"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Presence members",
      "description": "Room membership (V3 soft state). Shown as an aggregate; if you label the metric by topic, swap the query for `sum by (topic) (realtime_pubsub_presence_members)` to get one line per room (watch cardinality with client-controlled topic names).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 20
          },
          "color": { "mode": "fixed", "fixedColor": "purple" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(realtime_pubsub_presence_members)",
          "legendFormat": "members"
        }
      ]
    }
  ]
}
