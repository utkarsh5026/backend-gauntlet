# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# Server (HTTP listener; the WebSocket endpoint is GET /ws and upgrades here)
PORT=8080
RUST_LOG=info,realtime_pubsub=debug,redis=warn
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# A stable id for THIS node, stamped onto every message put on the cross-node
# bus so a node can recognise and drop its own echoes (V4 loop prevention).
NODE_ID=node-a

# --- Multi-node fan-out (V4) ---
# CLUSTER=false runs a single in-process hub (V1–V3 only); the broker isn't used.
# CLUSTER=true bridges the local hub to Redis pub/sub so subscribers on other
# nodes receive broadcasts published here.
CLUSTER=false
REDIS_URL=redis://localhost:6303/0

# --- WebSocket upgrade auth (security) ---
# Required shared secret on `GET /ws?token=...`. A browser WebSocket can't set
# custom headers on the handshake, so the token rides the query string. Unset
# (empty) means every upgrade is rejected — fail closed, not "auth disabled".
WS_AUTH_TOKEN=

# --- Per-connection backpressure (V2) ---
# How many queued-but-unsent messages one slow client may buffer before the
# overflow policy kicks in. Small on purpose: a slow consumer must NOT let the
# broadcaster accumulate unbounded memory.
OUTBOX_CAPACITY=64
# What to do when a client's outbox is full: drop_oldest | drop_newest | disconnect
OVERFLOW_POLICY=drop_oldest

# --- Admin-panel roster DB (OPTIONAL — playground scaffolding, not the SPEC) ---
# The people/groups/memberships behind the frontend admin panel live in Postgres.
# The pub/sub core (V1–V4) is store-free and runs WITHOUT this — leave it unset to
# disable the /admin API. Uncomment (and `docker compose up -d postgres`) to turn
# the admin panel on. Host port 5403 per the repo convention (postgres → 54NN).
# DATABASE_URL=postgres://pubsub:pubsub@localhost:5403/pubsub

# --- Presence heartbeat + TTL (V3) ---
# A member not refreshed (via a ClientMessage::Heartbeat) within this many
# seconds is presumed gone and swept. Keep it a healthy multiple of the
# client's heartbeat interval so one missed beat doesn't evict a live member.
PRESENCE_TTL_SECS=30
# How often the background sweep task checks for expired members.
PRESENCE_SWEEP_INTERVAL_SECS=10
