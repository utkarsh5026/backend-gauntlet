# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# Server (HTTP listener; the WebSocket endpoint is GET /ws and upgrades here)
PORT=8080
RUST_LOG=info,realtime_pubsub=debug,redis=warn
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# A stable id for THIS node, stamped onto every message put on the cross-node
# bus so a node can recognise and drop its own echoes (V4 loop prevention).
NODE_ID=node-a

# --- Multi-node fan-out (V4) ---
# CLUSTER=false runs a single in-process hub (V1–V3 only); the broker isn't used.
# CLUSTER=true bridges the local hub to Redis pub/sub so subscribers on other
# nodes receive broadcasts published here.
CLUSTER=false
REDIS_URL=redis://localhost:6303/0

# --- Per-connection backpressure (V2) ---
# How many queued-but-unsent messages one slow client may buffer before the
# overflow policy kicks in. Small on purpose: a slow consumer must NOT let the
# broadcaster accumulate unbounded memory.
OUTBOX_CAPACITY=64
# What to do when a client's outbox is full: drop_oldest | drop_newest | disconnect
OVERFLOW_POLICY=drop_oldest
