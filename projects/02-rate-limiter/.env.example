# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# Server (gRPC listens here; 50051 is the conventional gRPC dev port)
PORT=50051
RUST_LOG=info,rate_limiter=debug,redis=warn
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# Redis holds the shared limiter state (matches docker-compose.yml)
REDIS_URL=redis://localhost:6302/0

# Default limit applied to every key (per-tier config comes later).
# Sustained refill rate in tokens/sec, and the burst (bucket capacity).
RATE_PER_SEC=10
BURST=20

# Which algorithm the distributed limiter uses: token_bucket | sliding_window
ALGORITHM=token_bucket

# Failure mode when Redis is unreachable:
#   true  = fail open (allow the request — availability over protection)
#   false = fail closed (deny — protection over availability)
FAIL_OPEN=true
