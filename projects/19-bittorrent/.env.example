# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# HTTP control plane (add torrents, inspect progress, /metrics, /healthz)
PORT=8080
RUST_LOG=info,bittorrent=debug
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# The port we listen on for INBOUND peers (advertised to the tracker). Convention:
# BitTorrent uses 6881–6889; the project-scoped host default is 6819 (6881 → NN=19).
# Keep this in lockstep with the DEFAULT_PEER_PORT fallback in src/main.rs.
PEER_PORT=6819

# Where downloaded/seeded piece data is stored (gitignored).
DOWNLOAD_DIR=./data

# --- Resource caps (the anti-flash-crowd bounds — see the boss fight) ---
# Max simultaneous peer connections across all torrents.
MAX_PEERS=50
# Regular upload slots for the seeder's choke algorithm (V6): at most this many peers
# are unchoked at once (+1 optimistic). This is the cap the boss fight verifies.
UPLOAD_SLOTS=4

# --- Seeder (V6) ---
# Off by default so the bare scaffold serves the control plane without the accept-loop
# panicking on its first (todo!()) inbound peer. Flip on once V6 is implemented.
RUN_SEEDER=false

# --- Test swarm (docker compose up) --------------------------------------------------
# These aren't read by the app — they're where the compose dependencies live, for when
# you announce/leech/seed against them. Host ports are project-scoped (NN=19).
#   Tracker (opentracker, HTTP + UDP):   http://localhost:6919/announce   udp://localhost:6919
#   Reference peer (transmission) RPC:   http://localhost:9019/transmission/web/
#   Reference peer BitTorrent port:      51419  (TCP + UDP)
