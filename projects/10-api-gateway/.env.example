# Copy to .env and adjust. Every value has a sane default — a bare `cargo run`
# proxies to a single catch-all pool (UPSTREAM_BACKENDS below).

# --- listener ---
# Port the gateway listens on for client traffic + admin/metrics.
PORT=8080

# --- routing config ---
# Path to a JSON route table (see gateway.example.json). If unset/empty, the
# gateway builds a built-in catch-all route ("/" → UPSTREAM_BACKENDS) so you need
# zero files to run the demo.
CONFIG_PATH=
# Comma-separated host:port backends for the built-in catch-all route.
UPSTREAM_BACKENDS=127.0.0.1:9001,127.0.0.1:9002
# Load-balancing policy for the catch-all route: round_robin | least_conn | p2c
LB_POLICY=round_robin

# --- resilience / timeouts (V1 / V4) ---
# Max time a single upstream TCP connect may take before it's a 502.
UPSTREAM_CONNECT_TIMEOUT_MS=2000
# Overall per-request deadline (connect + upstream response) before a 504.
REQUEST_TIMEOUT_MS=10000
# Active health-check probe interval (V4).
HEALTH_PROBE_MS=2000
# Circuit breaker (V4): failures before it opens, and the open cooldown.
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_OPEN_COOLDOWN_MS=5000

# --- edge limits (security) ---
# Reject a request body larger than this many bytes (413).
MAX_BODY_BYTES=8388608

# --- mTLS (security, src/tls.rs) — all optional; plain HTTP when unset ---
# Server cert + key the gateway presents to clients (TLS termination).
# TLS_CERT=./certs/gateway.crt
# TLS_KEY=./certs/gateway.key
# CA to verify *client* certs against — set to require mTLS at the edge.
# TLS_CLIENT_CA=./certs/client-ca.crt
# CA + client identity for mutual TLS to upstreams.
# UPSTREAM_TLS_CA=./certs/upstream-ca.crt
# UPSTREAM_CLIENT_CERT=./certs/gateway-client.crt
# UPSTREAM_CLIENT_KEY=./certs/gateway-client.key
