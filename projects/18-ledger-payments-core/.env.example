# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# HTTP API (accounts, transfers, balances)
PORT=8080
RUST_LOG=info,ledger_payments_core=debug,sqlx=warn
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# Postgres — the transactional source of truth (accounts, entries, idempotency,
# outbox). Host port 5418 = 54NN with NN=18; keep this in lockstep with the code
# fallback and docker-compose.yml.
DATABASE_URL=postgres://ledger:ledger@localhost:5418/ledger
DB_MAX_CONNECTIONS=20

# Redis — idempotency response cache (V3). Cache only; Postgres is the record.
REDIS_URL=redis://localhost:6318

# --- Security ---
# API key required on write/read routes. Comma-separated to allow rotation.
API_KEYS=dev-key-change-me
# Ceiling on a single transfer, in minor units (e.g. 100000000 = $1,000,000.00).
MAX_TRANSFER_MINOR=100000000

# --- Idempotency (V3) ---
# How long a stored idempotency result is replayable. After this, the same key is
# treated as a brand-new request (documented in docs/18-design.md).
IDEMPOTENCY_TTL_SECS=86400

# --- Isolation / retries (V2) ---
# A SERIALIZABLE conflict (SQLSTATE 40001) is retried, not surfaced as a 500.
# This caps how many times before the transfer is rejected cleanly.
MAX_SERIALIZATION_RETRIES=5

# --- Webhooks (V4) ---
# Off by default so the bare scaffold serves the API without a dispatcher panicking
# on its first (todo!()) outbox claim. Flip on once V4 is implemented.
RUN_DISPATCHER=false
# Shared secret used to HMAC-SHA256 sign each delivery. NEVER log this.
WEBHOOK_SIGNING_SECRET=whsec_change_me
# Where settlement events go (a single sink for the scaffold; real systems store a
# per-account endpoint). Point this at your test receiver.
WEBHOOK_ENDPOINT_URL=http://localhost:9000/webhooks
WEBHOOK_MAX_ATTEMPTS=8         # deliveries before dead-lettering
WEBHOOK_DISPATCH_INTERVAL_MS=1000
WEBHOOK_DISPATCH_BATCH=50      # events claimed per dispatch round
