# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# Control-plane HTTP API (submit + inspect jobs)
PORT=8080
RUST_LOG=info,transcode_pipeline=debug,sqlx=warn
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# Postgres — the durable DAG store (jobs, tasks, dependency edges, leases).
DATABASE_URL=postgres://transcode:transcode@localhost:5412/transcode
DB_MAX_CONNECTIONS=20

# Artifact store: sources, per-chunk transcodes, and finished renditions all live
# under here (nothing may escape it). Drop a source at e.g. $WORK_DIR/bbb.mp4 and
# submit `{"source": "bbb.mp4"}`.
WORK_DIR=./work

# External codec toolbox — must be on PATH (or point at a specific build).
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# --- Chunking (V1) ---
# Desired chunk length; the keyframe boundary always wins, so real chunks cluster
# around this rather than hitting it exactly.
TARGET_CHUNK_SECS=6

# --- Coordinator: scheduler + worker pool ---
# Off by default so the bare scaffold serves the control-plane API without
# panicking. The scheduler's first tick calls the V2/V3 store methods (todo!()),
# so flip this on once the DAG store works.
RUN_WORKERS=false
WORKER_CONCURRENCY=4         # parallel transcodes in flight per process
SCHEDULER_INTERVAL_MS=500    # how often Pending→Ready promotion + lease reaping runs
POLL_INTERVAL_MS=500         # how often an idle worker re-checks for a Ready task

# --- Leases / retries (V3) ---
# How long a claimed task stays leased before the reaper assumes the worker died
# and makes it claimable again. Too short = a slow transcode gets double-run; too
# long = slow recovery from a crashed worker (a straggling chunk stalls the stitch).
LEASE_SECS=120
MAX_ATTEMPTS=3               # transcode attempts before a task is dead-lettered
