# WebRTC SFU — copy to `.env` (gitignored) and adjust. There is no database and no
# docker-compose here: the SFU *is* the media server. Everything lives in-process.

# UDP port the media plane (STUN/ICE + RTP/RTCP) binds. Real clients ICE-connect here.
MEDIA_PORT=7000

# HTTP port for the signaling API (join / publish / subscribe) + admin (/healthz, /metrics).
HTTP_PORT=8080

# The address the SFU advertises as its ICE host candidate. On localhost this is
# 127.0.0.1; on a server set it to the reachable public IP so browsers can send to it.
PUBLIC_IP=127.0.0.1

# Safety caps (an open UDP port + a public signaling API take input from anyone).
MAX_ROOMS=64
MAX_PEERS_PER_ROOM=64

# Per-subscriber downlink bandwidth estimate bounds (kbps) for the estimator + allocator.
MIN_KBPS=150
START_KBPS=1000
MAX_KBPS=4000
