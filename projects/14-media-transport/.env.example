# Copy to .env (gitignored) and adjust. All values have defaults; nothing here is a secret.

# --- roles & sockets ---
# Which side this process plays: `receiver` (binds and consumes) or `sender` (produces).
ROLE=receiver
# UDP port for the RTP/RTCP media plane.
RTP_PORT=5004
# TCP port for the admin/observability HTTP surface (/healthz, /readyz, /status, /metrics).
HTTP_PORT=8080
# Sender only: where to send RTP (host:port of the receiver). Required for ROLE=sender.
# REMOTE_ADDR=127.0.0.1:5004

# --- packetization (V1) ---
# Max UDP payload per packet (header + media). 1200 stays under the common 1500-byte path
# MTU with room for IP/UDP + tunnels, avoiding IP-layer fragmentation.
MTU=1200
# RTP payload type (96 = a dynamic type, typical for H.264).
PAYLOAD_TYPE=96

# --- jitter buffer (V2) ---
# Target playout delay in ms: how long a packet waits before it may be released. Bigger =
# smoother under jitter, but more latency.
PLAYOUT_MS=100

# --- congestion control (V4), in kilobits/sec ---
START_KBPS=1500
MIN_KBPS=300
MAX_KBPS=4000

# --- synthetic media source (sender, when no real RTP feed is used) ---
FPS=30
# Keyframe interval, in frames.
GOP=60
