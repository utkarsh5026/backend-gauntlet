# Copy to `.env` and adjust. `.env` is gitignored — never commit real secrets.

# HTTP API. 9200 is the Elasticsearch HTTP-port convention.
PORT=9200
RUST_LOG=info,full_text_search=debug
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# --- Storage ---
# Where the index lives. The engine creates shard-<n>/ subdirectories of immutable
# segment files under here. The filesystem IS the index — there is no other
# dependency (no Postgres, no Redis, no Elasticsearch).
INDEX_DIR=./data

# Number of shards the corpus is partitioned across (V5). Each shard is an
# independent inverted index; a search fans out to all of them and merges the
# top-k. Fixed at startup — changing it re-hashes every document (a reindex, not a
# config flip). Kept small for local dev; a real cluster runs one shard per core-ish.
SHARD_COUNT=3

# Auto-refresh cadence (V2): flush each shard's in-memory buffer to a new on-disk
# segment every this-many milliseconds so freshly indexed docs become searchable.
# 0 disables the background refresher (the default, so the bare scaffold serves
# cleanly without a task panicking on a not-yet-built flush) — call POST /_refresh
# by hand instead. ES defaults this to 1000ms.
REFRESH_INTERVAL_MS=0

# --- BM25 ranking (V3) ---
# k1 controls term-frequency saturation (higher = more reward for repeats);
# b controls document-length normalization (0 = none, 1 = full). These are the
# Lucene/Elasticsearch defaults — a good place to start, then tune and document.
BM25_K1=1.2
BM25_B=0.75

# --- Segment merging (V4) ---
# A shard accumulates many small segments (one per refresh); merging compacts them
# and drops tombstoned docs. Trigger a merge once a shard holds more than this many
# segments (a simple tiered policy). POST /_forcemerge merges on demand.
MERGE_FACTOR=10

# --- Query cache (caching horizontal) ---
# Max number of (query → results) entries cached at the coordinator, invalidated
# whenever a refresh or merge changes what's searchable. 0 disables the cache — the
# default while it's unbuilt, so search doesn't touch a not-yet-written cache. Set
# >0 once you build it.
QUERY_CACHE_CAP=0

# --- Security ---
# API key(s) required on write/admin routes (index, bulk, delete, refresh, merge).
# Search is public. Comma-separated to allow rotation. Never logged.
API_KEYS=dev-key-change-me
# Hard cap on a single document's text, in bytes — one client can't stream you out
# of disk. Enforced on index/bulk before anything is buffered.
MAX_DOC_BYTES=1048576         # 1 MiB
# Reject pathological queries: cap the number of terms a single query may contain
# after analysis, so a 10k-term query can't fan out into a scan of every segment.
MAX_QUERY_TERMS=64
