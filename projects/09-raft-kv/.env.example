# Copy to `.env` and adjust. `.env` is gitignored — never commit real secrets.
#
# A Raft cluster is N processes sharing one PEERS map, each with its own NODE_ID.
# For a local 3-node cluster, run three copies with NODE_ID=1,2,3 (see below) —
# each reads the SAME PEERS but a DIFFERENT NODE_ID. There's no shared config
# server: the cluster membership IS this list.

# --- This node's identity ---
NODE_ID=1

# --- The cluster: id=host:port, comma-separated. Include THIS node. ---
# The port here is also the port this node binds. A single-node default lets
# `cargo run -p raft-kv` boot with no env at all.
PEERS=1=127.0.0.1:9001,2=127.0.0.1:9002,3=127.0.0.1:9003

RUST_LOG=info,raft_kv=debug
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# --- Storage ---
# Each node persists its term/vote/log under DATA_DIR/node-<NODE_ID>/. Raft
# safety depends on this surviving a crash — the filesystem is the durable state.
DATA_DIR=./data

# --- Timing (V1) ---
# Heartbeat cadence for a leader. Must stay WELL BELOW the election-timeout floor,
# or healthy followers time out and start needless elections.
HEARTBEAT_MS=50
# Election timeout is drawn uniformly from [MIN, MAX] per attempt. The spread is
# what breaks split votes — keep MAX a few× the heartbeat, and MIN > a round-trip.
ELECTION_MIN_MS=150
ELECTION_MAX_MS=300

# --- Compaction (V4) ---
# Snapshot the state machine and compact the log once this many entries pile up.
SNAPSHOT_THRESHOLD=1000

# --- Run a 3-node cluster locally (three terminals) ---
# NODE_ID=1 cargo run -p raft-kv
# NODE_ID=2 cargo run -p raft-kv
# NODE_ID=3 cargo run -p raft-kv
