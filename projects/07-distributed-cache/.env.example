# Copy to .env and adjust. Every value has a sane default — a bare `cargo run`
# starts a single standalone node.

# --- identity & networking ---
# Stable id used to place this node on the hash ring. Keep it constant across
# restarts (a random one reshuffles the whole ring). Defaults to host:PORT.
NODE_ID=cache-a
# Address peers use to reach this node. localhost for single-box dev; the docker
# service name (cache-a, …) inside the compose cluster.
ADVERTISE_HOST=127.0.0.1
# Client + internal HTTP API port.
PORT=8070
# SWIM gossip UDP port.
GOSSIP_PORT=7070
# Comma-separated host:GOSSIP_PORT of seed peers to join through. Empty = this
# node is the first / standalone. e.g. SEEDS=127.0.0.1:7071,127.0.0.1:7072
SEEDS=

# --- local store (V1) ---
# Hard cap on entries per node; a full store evicts before inserting a new key.
CACHE_CAPACITY=100000
# Eviction policy: lru | lfu
EVICTION_POLICY=lru
# Reject values larger than this many bytes.
MAX_VALUE_BYTES=1048576

# --- ring & replication (V2 / V4) ---
# Virtual nodes per physical node — higher flattens load, costs memory.
VNODES_PER_NODE=128
# Copies of each key across ring successors (survives this many-1 node losses).
REPLICATION_FACTOR=2
