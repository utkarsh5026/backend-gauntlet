# Copy to `.env` and adjust. `.env` is gitignored — never commit real secrets.

# HTTP API. 9092 is the Kafka broker-port convention.
PORT=9092
RUST_LOG=info,message_broker=debug
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# --- Storage ---
# Where the broker lives. It creates topics/<topic>/<partition>/ trees of
# segment (.log) + index (.index) files under here. The filesystem IS the
# broker — there is no other dependency.
DATA_DIR=./data

# Roll to a new segment once the active one exceeds this many bytes (V1). Kept
# small here so a modest test produces multiple segments; Kafka's default is
# 1 GiB. Must stay under 4 GiB — the sparse index (V2) stores byte positions as
# u32 relative to the segment start.
SEGMENT_BYTES=67108864       # 64 MiB

# Write a sparse index entry about every this-many bytes of log (V2). Smaller =
# faster seeks, more memory; larger = the reverse. Kafka's default is 4 KiB.
INDEX_INTERVAL_BYTES=4096

# Default partition count for a topic created without an explicit count (V3).
DEFAULT_PARTITIONS=3

# Hard cap on a single record's value, in bytes. Enforced on produce so one
# client can't stream the broker out of disk. Kafka's default is ~1 MiB.
MAX_RECORD_BYTES=1048576

# --- Auth (horizontal TODO) ---
# Gate produce + topic creation behind a credential once you wire it. An open
# produce endpoint is an open disk for the whole internet.
# WRITE_API_KEY=
