# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# HTTP API (enqueue + inspect)
PORT=8080
RUST_LOG=info,job_queue=debug,sqlx=warn
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# Shared bearer token required on the mutating routes (POST /jobs, requeue). Send it
# as `Authorization: Bearer <token>`. UNSET/empty = auth disabled (dev only) — main
# warns loudly, and with the exec/shell job kinds an open POST /jobs is remote code
# execution, so set this in any shared/prod environment.
ENQUEUE_TOKEN=

# Postgres — the durable store AND the queue (claim via FOR UPDATE SKIP LOCKED).
DATABASE_URL=postgres://jobs:jobs@localhost:5404/jobs
DB_MAX_CONNECTIONS=20

# --- Worker pool ---
# Off by default so the bare scaffold serves the enqueue API without panicking.
# The worker loop calls the V1 claim (todo!()), so flip this on once V1 works.
RUN_WORKERS=false
WORKER_CONCURRENCY=4
QUEUE=default
POLL_INTERVAL_MS=1000        # how often an idle worker re-checks (V4 replaces with LISTEN/NOTIFY)
CLAIM_BATCH=10               # jobs claimed per round-trip

# --- Visibility timeout / lease (V2) ---
# How long a claimed job stays invisible before the reaper assumes the worker
# died and makes it claimable again. Too short = spurious double-runs of slow
# jobs; too long = slow recovery from a crashed worker.
VISIBILITY_TIMEOUT_SECS=30
REAPER_INTERVAL_SECS=10

# --- Retries (V3) ---
DEFAULT_MAX_ATTEMPTS=5
