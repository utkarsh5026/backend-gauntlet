# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.
#
# One process is ONE regional SFU. To run a cascade, launch several instances with
# different REGION / NODE_ID / ports / PEERS (see SPEC.md "Run it"). There is no
# Postgres/Redis/NATS: the control plane is consensus this binary builds (V1), the
# media plane is SFU-to-SFU UDP (V2), and recordings are written to local disk (V4).

# --- This node's identity in the mesh ---
REGION=eu-west               # this SFU's region (also the home-region label for rooms it anchors)
NODE_ID=n1                   # stable id for THIS node (used in consensus + logs; in k8s, the pod name)

# --- HTTP: signaling + inter-SFU cluster control + admin all share this listener ---
HTTP_PORT=8080
RUST_LOG=info,global_conferencing=debug
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# --- Media planes (UDP) ---
MEDIA_PORT=7000              # participant-facing muxed socket (STUN/RTP/RTCP), as in project 15
CASCADE_PORT=7100            # backbone socket that relays media between SFUs (V2)
# The address this SFU advertises to clients as its ICE host candidate (where they send
# their STUN checks + media). Set to the node's reachable IP in a real deployment.
PUBLIC_IP=127.0.0.1

# --- The mesh: the other regional SFUs (V1 consensus peers + V2 relay targets) ---
# Comma-separated `region=<http-control-base>|<cascade-udp-addr>`. Empty = a lone SFU
# (single region, no cascade — behaves like project 15). Example for a 3-region mesh:
#   PEERS=us-east=http://127.0.0.1:8081|127.0.0.1:7101,ap-south=http://127.0.0.1:8082|127.0.0.1:7102
PEERS=

# --- Bounds (backpressure / abuse protection) ---
MAX_ROOMS=256                # cluster-wide cap, enforced through the placement log (V1)
MAX_PEERS_PER_ROOM=512
MAX_RELAY_LINKS=16           # cap on concurrent backbone legs this SFU opens (V2)

# --- Placement consensus (V1) — the Raft-lite knobs from project 09 ---
# Randomized election timeout base (ms): a follower waits a random interval in
# [ELECTION_TIMEOUT_MS, 2*ELECTION_TIMEOUT_MS) before standing for election, so split
# votes resolve. Heartbeat should be comfortably below this.
ELECTION_TIMEOUT_MS=1000
HEARTBEAT_MS=300

# --- Simulcast layers (V3) — the ladder a publisher announces; the ids the cascade routes ---
# Informational default for the demo publish; real layers come from the publish request.

# --- Recording (V4) ---
RECORDING_DIR=./recordings   # where segmented recordings are written
SEGMENT_SECS=6               # recording segment length (crash loses at most one open segment)

# --- Background loops (placement election/heartbeat, cascade dialing) ---
# Off by default so the bare scaffold serves the API without driving a V1/V2 todo!() with no
# input. Flip to true (and set PEERS) once those verticals are implemented, to run a live mesh.
RUN_BACKGROUND=false
