{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "title": "URL Shortener — Observability",
  "uid": "url-shortener",
  "tags": ["url-shortener", "backend-gauntlet"],
  "timezone": "",
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Redirects served (total)",
      "description": "The raw counter — total 3xx responses since the process started. Resets to 0 only on restart.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(url_shortener_redirects_total)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Redirects / sec (now)",
      "description": "Requests-per-second — the counter differentiated over a 1m window. This is the number the boss fight grades (target ≥ 5,000).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(url_shortener_redirects_total[1m]))"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cache hit ratio",
      "description": "hit / (hit + miss + negative), as a live rate. Boss-fight target ≥ 95% on the mixed workload.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(url_shortener_cache_lookups_total{outcome=\"hit\"}[5m])) / clamp_min(sum(rate(url_shortener_cache_lookups_total[5m])), 1)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Ingest queue depth",
      "description": "Live gauge: clicks buffered in the bounded ingestion channel. Rising toward the bound means the DB writer is falling behind (backpressure).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "purple" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "url_shortener_ingest_queue_depth"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Redirects per second — by cache outcome",
      "description": "sum by (cache) (rate(...[1m])). Splits the served traffic into cache hits vs misses so you can watch the hit line dominate once the cache warms.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (cache) (rate(url_shortener_redirects_total[1m]))",
          "legendFormat": "{{cache}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Cache lookups per second — by outcome",
      "description": "hit / miss / negative resolutions on the redirect path. A spike in 'miss' or 'negative' is the stampede / 404-flood signal.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (outcome) (rate(url_shortener_cache_lookups_total[1m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Cache hit ratio (%) over time",
      "description": "The hit-ratio trend. Watch it climb past 95% as the cache warms; a dip marks a cold-key event or a Redis outage falling back to Postgres.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(url_shortener_cache_lookups_total{outcome=\"hit\"}[1m])) / clamp_min(sum(rate(url_shortener_cache_lookups_total[1m])), 1)",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Ingestion queue depth over time",
      "description": "The bounded click channel's fill level. Sustained growth = the batched DB writer can't keep up; where it plateaus tells you the backpressure policy kicking in.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 20
          },
          "color": { "mode": "fixed", "fixedColor": "purple" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "url_shortener_ingest_queue_depth",
          "legendFormat": "queue depth"
        }
      ]
    }
  ]
}
