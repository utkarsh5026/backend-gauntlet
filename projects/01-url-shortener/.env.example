# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# Server
PORT=8080
RUST_LOG=info,url_shortener=debug,sqlx=warn
LOG_FORMAT=pretty            # or `json` for production-style structured logs

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://shortener:shortener@localhost:5432/shortener

# Redis
REDIS_URL=redis://localhost:6379

# This instance's node id for the Snowflake ID generator.
# MUST be unique per running instance (0..=1023). See src/id_gen.rs.
NODE_ID=1

# Comma-separated API keys accepted on write/stats endpoints.
# In a real system these'd be hashed in a DB; this is the scaffold's stand-in.
API_KEYS=dev-secret-key
