#!/usr/bin/env bash
# Blocks pushes that would fail CI's fmt (+ hakari when available) lint gate.
# Install once: make hooks
# Bypass (rare): SKIP_GIT_HOOKS=1 git push ...
set -euo pipefail

if [[ "${SKIP_GIT_HOOKS:-}" == "1" ]]; then
  echo "↷ skipping pre-push (SKIP_GIT_HOOKS=1)"
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
exec "$ROOT/tools/preflight.sh" --lint
