{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug live-ingest",
      "cargo": {
        "args": ["build", "--bin=live-ingest", "--package=live-ingest"],
        "filter": { "name": "live-ingest", "kind": "bin" }
      },
      "args": [],
      "cwd": "${workspaceFolder}/projects/13-live-ingest",
      "envFile": "${workspaceFolder}/projects/13-live-ingest/.env"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug url-shortener",
      "cargo": {
        "args": ["build", "--bin=url-shortener", "--package=url-shortener"],
        "filter": { "name": "url-shortener", "kind": "bin" }
      },
      "args": [],
      "cwd": "${workspaceFolder}/projects/01-url-shortener",
      "envFile": "${workspaceFolder}/projects/01-url-shortener/.env"
    },
    {
      "type": "debugpy",
      "request": "launch",
      "name": "Debug tools/status.py",
      "program": "${workspaceFolder}/tools/status.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "type": "debugpy",
      "request": "launch",
      "name": "Debug tools/status.py (project 13)",
      "program": "${workspaceFolder}/tools/status.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": ["13"],
      "justMyCode": true
    }
  ]
